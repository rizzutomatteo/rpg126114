<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane styleClass="schermata"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.unicam.cs.mpgc.rpg126114.gui.controller.ArchivioController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="barra-stato">
            <padding>
                <Insets bottom="10" left="14" right="14" top="10"/>
            </padding>
            <Label styleClass="intestazione" text="Archivio dei verdetti"/>
            <TextField fx:id="campoFiltro" prefWidth="260" promptText="Cerca per nome..."/>
            <Label fx:id="lblConteggi"/>
        </HBox>
    </top>
    <center>
        <ListView fx:id="listaVerdetti">
            <BorderPane.margin>
                <Insets bottom="12" left="14" right="14" top="12"/>
            </BorderPane.margin>
        </ListView>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" styleClass="barra-verdetti">
            <padding>
                <Insets bottom="12" left="14" right="14" top="12"/>
            </padding>
            <Button cancelButton="true" onAction="#onIndietro" text="Torna al rendiconto"/>
        </HBox>
    </bottom>
</BorderPane>
