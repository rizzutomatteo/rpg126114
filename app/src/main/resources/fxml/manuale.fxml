<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="14" styleClass="schermata"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg126114.gui.controller.ManualeController">
    <padding>
        <Insets bottom="30" left="40" right="40" top="30"/>
    </padding>
    <Label styleClass="titolo" text="Manuale del Funzionario"/>
    <TextArea fx:id="areaManuale" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>
    <Button cancelButton="true" onAction="#onIndietro" text="Torna al menu"/>
</VBox>
